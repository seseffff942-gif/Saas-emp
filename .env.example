# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: La URL de tu proyecto en Supabase (ej. https://xxxx.supabase.co)
SUPABASE_URL=MY_SUPABASE_URL

# SUPABASE_ANON_KEY: Tu clave anonima (anon) de Supabase
SUPABASE_ANON_KEY=MY_SUPABASE_ANON_KEY

# STRIPE_PUBLISHABLE_KEY: Clave pública para integración con Stripe (suscripciones)
STRIPE_PUBLISHABLE_KEY=MY_STRIPE_PUBLISHABLE_KEY
